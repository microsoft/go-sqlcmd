+func TestVSCodeSettingsPreservesOtherKeys(t *testing.T) {
+	if runtime.GOOS == "linux" {
+		t.Skip("Skipping on Linux due to ADS tool initialization issue in tools factory")
+	}
+
+	cmdparser.TestSetup(t)
+
+	vscode := &VSCode{}
